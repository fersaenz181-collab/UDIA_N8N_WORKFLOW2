    {
      "parameters": {
        "jsCode": "// Obtener el texto generado por \"Message a model\"\nconst raw = $json.output[0].content[0].text;\n\n// Limpiar posibles bloques Markdown\nconst cleaned = raw\n  .replace(/```json/g, '')\n  .replace(/```/g, '')\n  .trim();\n\n// Convertir el JSON de texto en un objeto\nconst data = JSON.parse(cleaned);\n\n// Devolver campos separados\nreturn [\n  {\n    json: {\n      nombre_cliente: data.nombre_cliente,\n      email_cliente: data.email_cliente,\n      nombre_mascota: data.nombre_mascota,\n      asunto: data.asunto,\n      correo: data.correo,\n      prompt_imagen: data.prompt_imagen\n    }\n  }\n];"
      },
